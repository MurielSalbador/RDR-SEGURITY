# MongoDB Atlas — cadena de conexión del cluster (nunca se pausa en el tier M0)
MONGODB_URI="mongodb+srv://usuario:password@cluster.mongodb.net/?retryWrites=true&w=majority"
MONGODB_DB_NAME="rdr_seguridad"

# Resend — API key para el envío de notificaciones por correo
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"

# Correo que recibe cada consulta del formulario (en minúsculas — Resend lo
# compara letra por letra contra el mail de la cuenta mientras se use onboarding@resend.dev)
CONTACT_TO_EMAIL="rdr.seguridadprivada@gmail.com"

# Remitente verificado en Resend (requiere dominio propio verificado; mientras tanto se puede usar onboarding@resend.dev)
CONTACT_FROM_EMAIL="RDR Seguridad Privada <onboarding@resend.dev>"
