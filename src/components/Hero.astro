<section class="hero">
  <canvas id="scene"></canvas>
  <div class="grid-texture"></div>
  <div class="mobile-status">
    <div class="m-card"><span class="dot"></span> ESTADO OPERATIVO: ACTIVO</div>
    <div class="m-card">MONITOREO · 24/7 · 365</div>
    <div class="m-card">ROSARIO · SANTA FE · AR</div>
  </div>
  <div class="hero-inner">
    <div>
      <div class="eyebrow">Seguridad privada integral</div>
      <h1>Protegemos lo que <em>más importa</em>, antes de que importe.</h1>
      <p class="lead">Acompañamos a empresas, barrios privados e instituciones con portería, monitoreo, patrullaje y custodia personal — con personal capacitado y supervisión constante.</p>
      <div class="hero-ctas">
        <a class="btn-primary" href="#contacto">Solicitar una consulta gratuita</a>
        <a class="btn-secondary" href="#servicios">Ver servicios</a>
      </div>
    </div>
    <div class="hero-shield">
      <div class="hero-shield-ring"></div>
      <div class="hero-shield-ring r2"></div>
      <div class="hero-shield-frame">
        <img src="/rdr-logo.png" alt="Escudo RDR" />
      </div>
    </div>
  </div>
  <div class="scroll-cue"><div class="line"></div>SCROLL</div>
</section>

<script>
(function(){
  const canvas = document.getElementById('scene') as HTMLCanvasElement;
  if(!canvas) return;
  const ctx = canvas.getContext('2d');
  if(!ctx) return;
  let W: number, H: number, DPR: number;

  const ACCENT = [91,143,199];
  const SILVER = [238,241,245];
  const BRIGHT = [150,195,240];

  let mapDots: any[] = [], netNodes: any[] = [], netLinks: any[] = [], pulses: any[] = [], pings: any[] = [];
  let center = {x:0, y:0}, radarR = 0, sweep = 0;
  const SWEEP_SPEED = 0.9;

  // Continentes: [x, y, rx, ry] normalizados sobre el mapa
  const CONT = [
    [0.15,0.24,0.075,0.10],[0.20,0.31,0.06,0.09],[0.12,0.34,0.04,0.06],[0.23,0.20,0.055,0.05],
    [0.31,0.13,0.03,0.055],
    [0.26,0.57,0.05,0.075],[0.28,0.68,0.042,0.09],[0.255,0.80,0.02,0.05],
    [0.485,0.24,0.045,0.05],[0.46,0.30,0.03,0.04],
    [0.505,0.47,0.05,0.07],[0.525,0.58,0.045,0.08],[0.505,0.67,0.03,0.055],
    [0.62,0.25,0.085,0.09],[0.71,0.21,0.085,0.07],[0.66,0.34,0.06,0.06],
    [0.60,0.30,0.04,0.05],[0.745,0.35,0.05,0.05],[0.79,0.41,0.04,0.04],
    [0.82,0.70,0.05,0.05],
    [0.80,0.30,0.016,0.032],[0.765,0.47,0.03,0.02]
  ];

  function inContinent(nx: number, ny: number){
    for(let i=0;i<CONT.length;i++){
      const c=CONT[i];
      const dx=(nx-c[0])/c[2], dy=(ny-c[1])/c[3];
      const d = dx*dx+dy*dy;
      const edge = 1 + (Math.sin(nx*57.1+ny*31.7)*0.18);
      if(d < edge) return true;
    }
    return false;
  }

  function lerp(a: number[], b: number[], t: number){ t=Math.max(0,Math.min(1,t));
    return [Math.round(a[0]+(b[0]-a[0])*t),Math.round(a[1]+(b[1]-a[1])*t),Math.round(a[2]+(b[2]-a[2])*t)]; }

  function angDiff(a: number, b: number){ let d=(a-b)%(Math.PI*2); if(d<0)d+=Math.PI*2; return d; }

  function build(){
    if(!canvas) return;
    DPR = Math.min(window.devicePixelRatio||1, 2);
    W = canvas.clientWidth; H = canvas.clientHeight;
    canvas.width = W*DPR; canvas.height = H*DPR;
    ctx!.setTransform(DPR,0,0,DPR,0,0);

    center.x = W*0.685;
    center.y = H*0.52;
    radarR = Math.min(W*0.34, H*0.46);

    const mapX0 = W*0.30, mapX1 = W*1.02;
    const mapY0 = H*0.10, mapY1 = H*0.94;
    const mapW = mapX1-mapX0, mapH = mapY1-mapY0;
    const step = Math.max(8, Math.round(W/150));

    mapDots = [];
    for(let x=mapX0; x<mapX1; x+=step){
      for(let y=mapY0; y<mapY1; y+=step){
        const nx=(x-mapX0)/mapW, ny=(y-mapY0)/mapH;
        if(inContinent(nx,ny)){
          const px=x+(Math.random()-0.5)*step*0.5;
          const py=y+(Math.random()-0.5)*step*0.5;
          const ang=(Math.atan2(py-center.y, px-center.x)+Math.PI*2)%(Math.PI*2);
          mapDots.push({x:px,y:py,ang:ang,base:0.18+Math.random()*0.22,
            tw:Math.random()*Math.PI*2, r:0.9+Math.random()*0.7, glow:0});
        }
      }
    }

    netNodes = [];
    const NODE_COUNT = Math.round(W/26);
    for(let i=0;i<NODE_COUNT;i++){
      const bias = Math.pow(Math.random(),0.7);
      const px = mapX0 + mapW*(0.15 + bias*0.85);
      const py = mapY0 + mapH*Math.random();
      const ang=(Math.atan2(py-center.y, px-center.x)+Math.PI*2)%(Math.PI*2);
      netNodes.push({x:px,y:py,ang:ang,r:1.1+Math.random()*1.7,
        tw:Math.random()*Math.PI*2, glow:0});
    }
    netLinks = [];
    const maxD = W*0.11;
    for(let i=0;i<netNodes.length;i++){
      let cnt=0;
      for(let j=i+1;j<netNodes.length && cnt<3;j++){
        const dx=netNodes[i].x-netNodes[j].x, dy=netNodes[i].y-netNodes[j].y;
        const d=Math.hypot(dx,dy);
        if(d<maxD){ netLinks.push({a:i,b:j}); cnt++; }
      }
    }
    pulses = [];
    for(let k=0;k<Math.min(14,netLinks.length);k++){
      pulses.push({link:(Math.random()*netLinks.length)|0, t:Math.random(), sp:0.15+Math.random()*0.25});
    }
  }

  let last = performance.now();
  let pingTimer = 0;

  function frame(now: number){
    if(!canvas || !ctx) return;
    const dt = Math.min(0.05,(now-last)/1000); last=now;
    sweep = (sweep + SWEEP_SPEED*dt) % (Math.PI*2);
    ctx.clearRect(0,0,W,H);

    // Resplandor central
    const g = ctx.createRadialGradient(center.x,center.y,0,center.x,center.y,radarR*1.15);
    g.addColorStop(0,'rgba(91,143,199,0.16)');
    g.addColorStop(0.45,'rgba(91,143,199,0.05)');
    g.addColorStop(1,'rgba(91,143,199,0)');
    ctx.fillStyle=g;
    ctx.beginPath(); ctx.arc(center.x,center.y,radarR*1.15,0,Math.PI*2); ctx.fill();

    // Mapa mundial
    const trail = 0.7;
    for(let i=0;i<mapDots.length;i++){
      const d=mapDots[i];
      const behind = angDiff(sweep, d.ang);
      const dist = Math.hypot(d.x-center.x, d.y-center.y);
      let target = 0;
      if(behind < trail && dist < radarR*1.05){
        target = (1 - behind/trail) * (1 - dist/(radarR*1.15))*1.4;
      }
      if(target > d.glow) d.glow = target;
      d.glow *= 0.955;
      d.tw += dt*1.5;
      const tw = 0.5 + 0.5*Math.sin(d.tw);
      const b = Math.min(1, d.base*(0.7+0.3*tw) + d.glow);
      const col = lerp(SILVER,ACCENT,d.glow*0.6);
      ctx.beginPath();
      ctx.arc(d.x, d.y, d.r + d.glow*0.9, 0, Math.PI*2);
      ctx.fillStyle = 'rgba('+col[0]+','+col[1]+','+col[2]+','+b+')';
      ctx.fill();
    }

    // Anillos radar
    if (W > 600) {
      ctx.lineWidth=1;
      for(let i=1;i<=4;i++){
        ctx.beginPath();
        ctx.arc(center.x,center.y,radarR*i/4,0,Math.PI*2);
        ctx.strokeStyle='rgba(199,207,218,0.10)';
        ctx.stroke();
      }
      ctx.strokeStyle='rgba(199,207,218,0.08)';
      ctx.beginPath();
      ctx.moveTo(center.x-radarR,center.y); ctx.lineTo(center.x+radarR,center.y);
      ctx.moveTo(center.x,center.y-radarR); ctx.lineTo(center.x,center.y+radarR);
      ctx.stroke();

      // Haz de barrido
      ctx.save();
      ctx.translate(center.x,center.y);
      ctx.rotate(sweep);
      const seg=26, span=0.85;
      ctx.beginPath();
      ctx.moveTo(0,0);
      for(let i=0;i<=seg;i++){
        const a=-span*(i/seg);
        ctx.lineTo(Math.cos(a)*radarR, Math.sin(a)*radarR);
      }
      ctx.closePath();
      const lg = ctx.createRadialGradient(0,0,0,0,0,radarR);
      lg.addColorStop(0,'rgba(91,143,199,0.35)');
      lg.addColorStop(0.5,'rgba(91,143,199,0.14)');
      lg.addColorStop(1,'rgba(91,143,199,0)');
      ctx.fillStyle=lg;
      ctx.fill();
      ctx.beginPath();
      ctx.moveTo(0,0); ctx.lineTo(radarR,0);
      const lgl = ctx.createLinearGradient(0,0,radarR,0);
      lgl.addColorStop(0,'rgba(140,190,240,0.7)');
      lgl.addColorStop(1,'rgba(91,143,199,0)');
      ctx.strokeStyle=lgl; ctx.lineWidth=2; ctx.stroke();
      ctx.restore();
    }

    // Conexiones
    ctx.strokeStyle='rgba(91,143,199,0.12)';
    ctx.lineWidth=0.7;
    for(let i=0;i<netLinks.length;i++){
      const a=netNodes[netLinks[i].a], b=netNodes[netLinks[i].b];
      ctx.beginPath(); ctx.moveTo(a.x,a.y); ctx.lineTo(b.x,b.y); ctx.stroke();
    }
    // Pulsos
    for(let i=0;i<pulses.length;i++){
      const p=pulses[i];
      p.t += p.sp*dt;
      if(p.t>1){ p.t=0; p.link=(Math.random()*netLinks.length)|0; }
      const l=netLinks[p.link]; if(!l) continue;
      const a=netNodes[l.a], b=netNodes[l.b];
      const px=a.x+(b.x-a.x)*p.t, py=a.y+(b.y-a.y)*p.t;
      ctx.beginPath(); ctx.arc(px,py,1.4,0,Math.PI*2);
      ctx.fillStyle='rgba(150,195,240,0.9)'; ctx.fill();
    }

    // Nodos
    for(let i=0;i<netNodes.length;i++){
      const n=netNodes[i];
      const behind = angDiff(sweep, n.ang);
      const dist = Math.hypot(n.x-center.x, n.y-center.y);
      let target=0;
      if(behind < trail && dist < radarR*1.05){ target=(1-behind/trail); }
      if(target>n.glow) n.glow=target;
      n.glow*=0.95;
      n.tw+=dt*2;
      const tw=0.55+0.45*Math.sin(n.tw);
      const rr=n.r*(0.85+0.15*tw)+n.glow*1.2;
      if(n.glow>0.05){
        ctx.beginPath(); ctx.arc(n.x,n.y,rr*3,0,Math.PI*2);
        ctx.fillStyle='rgba(91,143,199,'+(0.12*n.glow)+')'; ctx.fill();
      }
      const col=lerp(SILVER,BRIGHT,n.glow);
      ctx.beginPath(); ctx.arc(n.x,n.y,rr,0,Math.PI*2);
      ctx.fillStyle='rgba('+col[0]+','+col[1]+','+col[2]+','+(0.55+0.4*tw)+')'; ctx.fill();
    }

    // Pings
    pingTimer -= dt;
    if(pingTimer<=0){
      pingTimer = 1.6 + Math.random()*2.2;
      const a=Math.random()*Math.PI*2;
      const rr=Math.random()*radarR*0.85;
      pings.push({x:center.x+Math.cos(a)*rr, y:center.y+Math.sin(a)*rr, t:0});
    }
    for(let i=pings.length-1;i>=0;i--){
      const p=pings[i]; p.t+=dt;
      const rad=p.t*40; const al=Math.max(0,1-p.t/1.4);
      ctx.beginPath(); ctx.arc(p.x,p.y,rad,0,Math.PI*2);
      ctx.strokeStyle='rgba(140,190,240,'+(al*0.6)+')'; ctx.lineWidth=1; ctx.stroke();
      ctx.beginPath(); ctx.arc(p.x,p.y,2,0,Math.PI*2);
      ctx.fillStyle='rgba(150,195,240,'+al+')'; ctx.fill();
      if(p.t>1.5) pings.splice(i,1);
    }

    requestAnimationFrame(frame);
  }

  window.addEventListener('resize', build);
  build();
  requestAnimationFrame(frame);
})();
</script>
